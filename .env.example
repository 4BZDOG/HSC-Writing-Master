# HSC AI Evaluator — Environment Configuration
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikeys
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Sentry Error Tracking (Optional)
# Get your DSN from: https://sentry.io
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=2.2.2

# Deployment Secrets (for GitHub Actions)
# Add these in your repository settings → Secrets and variables → Actions
# NETLIFY_AUTH_TOKEN: Your Netlify personal access token
# NETLIFY_SITE_ID: Your Netlify site ID
# SENTRY_AUTH_TOKEN: Your Sentry authentication token (for releases)
